---
import { getRuleFactCategory } from "@/data/rule-facts";
import RuleIndex from "./rule-index.astro";

import type { RuleCategoryKey } from "@/data/rule-manifest";

interface Props {
	readonly category: RuleCategoryKey;
}

const { category: categoryKey } = Astro.props;
const category = getRuleFactCategory(categoryKey);
---

<p class="rule-category-summary">
	{category.description}
	Browse all {category.count} {category.count === 1 ? "rule" : "rules"} in this category.
</p>

<RuleIndex category={categoryKey} />
