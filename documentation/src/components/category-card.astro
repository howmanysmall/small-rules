---
import Icon from "./icon.astro";

import type { RuleCategoryKey } from "@/data/rule-manifest";

interface Props {
	readonly category: RuleCategoryKey;
	readonly count: number;
	readonly description: string;
	readonly label: string;
}

const { label, count, description, category } = Astro.props;
const iconName = category;
const basePath = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<a class="category-card" data-category={category} href={`${basePath}rules/${category}/`}>
	<span aria-hidden="true" class="category-card-glow"></span>
	<div class="category-card-icon">
		<Icon name={iconName} size={22} />
	</div>
	<div class="category-card-body">
		<div class="category-card-head">
			<h3 class="category-card-title">{label}</h3>
			<span class="category-card-count">{count}</span>
		</div>
		<p class="category-card-desc">{description}</p>
		<span class="category-card-cta">
			Browse rules
			<Icon name="arrow-right" size={14} />
		</span>
	</div>
</a>
