---
import { getRuleFacts } from "@/data/rule-facts";

import type { RuleName } from "@/data/rule-manifest";

interface Props {
	readonly rule: RuleName;
}

const { rule } = Astro.props;
const { description } = getRuleFacts(rule);
---

<div class="rule-summary">
	<code class="rule-summary-id">small-rules/{rule}</code>
	<div class="rule-summary-text">
		<slot>
			<p>{description}</p>
		</slot>
	</div>
</div>
