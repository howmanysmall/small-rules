---
import { Code, TabItem, Tabs } from "@astrojs/starlight/components";

type Preset = "install" | "run";

interface Props {
	readonly preset?: Preset | undefined;
}

const { preset = "install" } = Astro.props;

const managers = [
	{ install: "aube add -D @pobammer-ts/small-rules oxlint", label: "aube", run: "aube run lint" },
	{ install: "npm install -D @pobammer-ts/small-rules oxlint", label: "npm", run: "npm run lint" },
	{ install: "pnpm add -D @pobammer-ts/small-rules oxlint", label: "pnpm", run: "pnpm run lint" },
	{ install: "yarn add -D @pobammer-ts/small-rules oxlint", label: "yarn", run: "yarn run lint" },
	{ install: "bun add -d @pobammer-ts/small-rules oxlint", label: "bun", run: "bun run lint" },
	{ install: "deno add -D npm:@pobammer-ts/small-rules npm:oxlint", label: "deno", run: "deno task lint" },
	{ install: "vlt install -D @pobammer-ts/small-rules oxlint", label: "vlt", run: "vlt run lint" },
	{ install: "vp add -D @pobammer-ts/small-rules oxlint", label: "vp", run: "vp run lint" },
	{ install: "ni -D @pobammer-ts/small-rules oxlint", label: "ni", run: "nr lint" },
];
---

<Tabs syncKey="package-manager">
	{
		managers.map(({ install, label, run }) => (
			<TabItem label={label}>
				<Code code={preset === "install" ? install : run} lang="bash" />
			</TabItem>
		))
	}
</Tabs>
