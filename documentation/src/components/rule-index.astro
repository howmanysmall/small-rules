---
import { ruleFactCategories } from "@/data/rule-facts";

import type { RuleCategoryKey } from "@/data/rule-manifest";

interface Props {
	readonly category?: RuleCategoryKey;
}

const { category: selectedCategory } = Astro.props;
const categories = [...ruleFactCategories.values()].filter(
	(category) => selectedCategory === undefined || category.key === selectedCategory,
);
const rules = categories.flatMap((category) =>
	category.rules.map((rule) => {
		let fixability: string | undefined;
		if (rule.fixable === undefined) {
			if (rule.hasSuggestions === true) fixability = "Editor suggestions";
		} else {
			fixability = rule.hasSuggestions === true ? "Automatic fix and editor suggestions" : "Automatic fix";
		}

		return {
			category: rule.category,
			description: rule.description,
			fixability,
			name: rule.name,
			path: rule.path,
			title: rule.title,
			type: rule.type,
		};
	}),
);
const basePath = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<div class="rule-index" data-rule-index>
	{selectedCategory === undefined && (
		<form class="rule-index-filters" data-rule-filters={true} hidden={true}>
			<div class="rule-index-field rule-index-field--search">
				<label for="rule-search">{"Search rules"}</label>
				<input
					autocomplete="off"
					data-rule-search={true}
					id="rule-search"
					name="query"
					placeholder="Try no-print"
					type="search"
				/>
			</div>
			<div class="rule-index-field">
				<label for="rule-category">{"Category"}</label>
				<select data-rule-category={true} id="rule-category" name="category">
					<option value="">{"All categories"}</option>
					{/* biome-ignore lint/performance/useSolidForComponent: Astro renders these options on the server. */}
					{categories.map((category) => (
						<option value={category.key}>{category.label}</option>
					))}
				</select>
			</div>
			<button class="rule-index-reset" type="reset">{"Reset filters"}</button>
		</form>
	)}

	<p aria-atomic="true" aria-live="polite" class="rule-index-count" data-rule-count>
		Showing {rules.length} {rules.length === 1 ? "rule" : "rules"}
	</p>

	<div class="rule-index-grid">
		{rules.map((rule) => (
			<a
				class="rule-index-card"
				data-rule-card={true}
				data-rule-category={rule.category}
					data-rule-search-text={`${rule.name} ${rule.title} ${rule.description}`.toLowerCase()}
				href={`${basePath}${rule.path}/`}
			>
				<div class="rule-index-card-heading">
					<h2>{rule.title}</h2>
					<span class="rule-index-card-category">{ruleFactCategories.get(rule.category)?.label}</span>
				</div>
				<code>{rule.name}</code>
				<p>{rule.description}</p>
				<ul aria-label="Rule characteristics">
					<li class="rule-index-card-trait">{rule.type === "problem" ? "Problem" : "Suggestion"}</li>
					{rule.fixability !== undefined && <li class="rule-index-card-trait">{rule.fixability}</li>}
				</ul>
			</a>
		))}
	</div>

	<p class="rule-index-empty" data-rule-empty hidden>No rules match those filters.</p>
</div>

<script>
	((): void => {
		const ruleIndex = document.querySelector("[data-rule-index]");
		if (!(ruleIndex instanceof HTMLElement)) return;

		const form = ruleIndex.querySelector("[data-rule-filters]");
		const search = ruleIndex.querySelector("[data-rule-search]");
		const category = ruleIndex.querySelector("[data-rule-category]");
		const count = ruleIndex.querySelector("[data-rule-count]");
		const emptyState = ruleIndex.querySelector("[data-rule-empty]");
		const cards = ruleIndex.querySelectorAll<HTMLElement>("[data-rule-card]");
		if (form instanceof HTMLFormElement) form.hidden = false;

		function updateRules(): void {
			if (!(search instanceof HTMLInputElement)) return;
			if (!(category instanceof HTMLSelectElement)) return;

			const query = search.value.trim().toLowerCase();
			let visibleCount = 0;

			for (const card of cards) {
				const matchesSearch = card.dataset.ruleSearchText?.includes(query) === true;
				const matchesCategory = category.value === "" || card.dataset.ruleCategory === category.value;
				card.hidden = !(matchesSearch && matchesCategory);
				if (!card.hidden) visibleCount += 1;
			}

			if (count instanceof HTMLElement) {
				count.textContent = `Showing ${visibleCount} ${visibleCount === 1 ? "rule" : "rules"}`;
			}
			if (emptyState instanceof HTMLElement) emptyState.hidden = visibleCount !== 0;
		}

		form?.addEventListener("input", updateRules);
		form?.addEventListener("reset", () => requestAnimationFrame(updateRules));
	})();
</script>
