# ── Registries ──────────────────────────────────────
@jsr:registry=https://npm.jsr.io

# ── Peer dependencies (pnpm/aube style) ─────────────
auto-install-peers=true
strict-peer-dependencies=true

# ── Node_modules layout ─────────────────────────────
# Prevent phantom dependencies by not hoisting everything
shamefully-hoist=false

# ── Lockfile ─────────────────────────────────────────
lockfile=true

# ── Engine checks ────────────────────────────────────
engine-strict=true
