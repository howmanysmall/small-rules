{
	"absolute": false,
	"blame": false,
	"exitCode": 1,
	"format": ["typescript", "javascript", "tsx", "jsx"],
	"gitignore": true,
	"ignore": ["**/{node_modules,dist,out,coverage,.stryker-tmp,.vitiate}/**"],
	"minLines": 5,
	"minTokens": 60,
	"noSymlinks": false,
	"path": ["src"],
	"reporters": ["html", "consoleFull", "json", "markdown"],
	"skipLocal": false,
	"threshold": 0
}
