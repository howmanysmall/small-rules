{
	"$schema": "https://opencode.ai/config.json",
	"agent": {
		"ask": {
			"color": "#7C3AED",
			"description": "General Q&A - ask questions about code, concepts, debugging strategies without executing anything",
			"disable": false,
			"mode": "all",
			"permission": {
				"bash": "allow",
				"codesearch": "allow",
				"doom_loop": "deny",
				"edit": "deny",
				"external_directory": "deny",
				"glob": "allow",
				"grep": "allow",
				"list": "allow",
				"lsp": "allow",
				"question": "allow",
				"read": "allow",
				"skill": "allow",
				"task": "allow",
				"todoread": "allow",
				"todowrite": "allow",
				"webfetch": "allow",
				"websearch": "allow",
			},
			"prompt": "# Q&A Assistant\n\nYou answer questions about code, architecture, debugging strategies, and technical concepts. You do NOT execute code or make edits—just provide knowledge.\n\n## Response Style\n\n- **Concise first** - lead with the direct answer, expand only if needed\n- **Code snippets** - show minimal examples when helpful, not full implementations\n- **No hedging** - if you know it, say it; if you don't, say that\n- **Cite sources** - mention docs/specs when relevant\n\n## What You Handle\n\n- Explain how X works\n- Debug strategy suggestions (without running anything)\n- API/library usage questions\n- Architecture tradeoffs\n- \"Why is this happening?\" conceptual debugging\n- Best practices and patterns\n- Compare/contrast approaches\n\n## What You Decline\n\n- \"Write me X\" (that's for coding agents)\n- \"Run this and tell me what happens\"\n- Tasks requiring file system access\n\nIf user needs execution or edits, tell them to switch agents.\n\n## Format\n\n- Short answers for short questions\n- Use headers only for multi-part responses\n- Code blocks with language tags\n- Lists only when comparing multiple items\n",
			"temperature": 0.3,
		},
	},
	"autoupdate": true,
	"command": {
		"goal": {
			"agent": "build",
			"description": "Set a session-scoped goal and auto-continue until complete.",
			"template": "$ARGUMENTS",
		},
	},
	"compaction": {
		"auto": true,
		"prune": true,
	},
	"disabled_providers": [],
	"experimental": {
		"batch_tool": true,
		"continue_loop_on_deny": false,
	},
	"formatter": {
		"biome": {
			"command": ["mise", "x", "--", "node", "--run", "biome", "format", "--write", "$FILE"],
			"extensions": [
				".astro",
				".cjs",
				".css",
				".cts",
				".gql",
				".graphql",
				".html",
				".js",
				".json",
				".jsonc",
				".jsx",
				".mjs",
				".mts",
				".scss",
				".svelte",
				".ts",
				".tsx",
				".vue",
				".yaml",
				".yml",
			],
		},
		"oxfmt": {
			"command": ["mise", "x", "--", "node", "--run", "oxfmt", "$FILE"],
			"extensions": [
				".cjs",
				".css",
				".cts",
				".gql",
				".graphql",
				".handlebars",
				".hbs",
				".htm",
				".html",
				".js",
				".json",
				".json5",
				".jsonc",
				".jsx",
				".less",
				".mdx",
				".mjs",
				".mts",
				".sass",
				".scss",
				".ts",
				".tsx",
				".vue",
				".yaml",
				".yml",
			],
		},
		"rumdl": {
			"command": ["mise", "x", "--", "rumdl", "check", "--fix", "$FILE"],
			"extensions": [
				".md",
				".markdown",
				".mdown",
				".mkdn",
				".mkd",
				".mdwn",
				".mdtxt",
				".mdtext",
				".text",
				".Rmd",
			],
		},
		"tombi": {
			"command": ["mise", "x", "--", "tombi", "format", "$FILE"],
			"extensions": [".toml"],
		},
	},
	"instructions": ["./AGENTS.md"],
	"lsp": {
		"biome": {
			"command": ["mise", "x", "--", "node", "--run", "biome", "lsp-proxy"],
			"extensions": [
				".astro",
				".cjs",
				".css",
				".cts",
				".gql",
				".graphql",
				".html",
				".js",
				".json",
				".jsonc",
				".jsx",
				".mjs",
				".mts",
				".scss",
				".svelte",
				".ts",
				".tsx",
				".vue",
				".yaml",
				".yml",
			],
		},
		"eslint": { "disabled": true },
		"oxfmt": {
			"command": ["mise", "x", "--", "node", "--run", "oxfmt", "--lsp"],
			"extensions": [
				".cjs",
				".css",
				".cts",
				".gql",
				".graphql",
				".handlebars",
				".hbs",
				".htm",
				".html",
				".js",
				".json",
				".json5",
				".jsonc",
				".jsx",
				".less",
				".mdx",
				".mjs",
				".mts",
				".sass",
				".scss",
				".ts",
				".tsx",
				".vue",
				".yaml",
				".yml",
			],
		},
		"oxlint": {
			"command": ["mise", "x", "--", "node", "--run", "oxlint", "--lsp"],
			"extensions": [".js", ".mjs", ".cjs", ".ts", ".mts", ".cts", ".jsx", ".tsx", ".vue", ".svelte", ".astro"],
		},
		"rumdl": {
			"command": ["mise", "x", "--", "rumdl", "server"],
			"extensions": [
				".md",
				".markdown",
				".mdown",
				".mkdn",
				".mkd",
				".mdwn",
				".mdtxt",
				".mdtext",
				".text",
				".Rmd",
			],
		},
		"tombi": {
			"command": ["mise", "x", "--", "tombi", "lsp"],
			"extensions": [".toml"],
		},
		"typescript": {
			"command": ["mise", "x", "--", "node", "--run", "tsgo", "--lsp", "--stdio"],
			"extensions": [".ts", ".tsx"],
		},
	},
	"mcp": {
		"astro-docs": {
			"type": "remote",
			"url": "https://mcp.docs.astro.build/mcp",
		},
		"chrome-devtools": {
			"command": ["bash", "./scripts/get-chrome-path.sh", "--serve"],
			"enabled": true,
			"type": "local",
		},
		"context7": {
			"enabled": true,
			"headers": { "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}" },
			"type": "remote",
			"url": "https://mcp.context7.com/mcp",
		},
		"gh-grep": {
			"enabled": false,
			"type": "remote",
			"url": "https://mcp.grep.app",
		},
		"github": {
			"enabled": false,
			"headers": { "Authorization": "Bearer {env:GITHUB_PAT}" },
			"type": "remote",
			"url": "https://api.githubcopilot.com/mcp/",
		},
		"jsr": {
			"command": ["mise", "x", "--", "jsr-cli", "mcp"],
			"enabled": false,
			"type": "local",
		},
		"npm-registry": {
			"command": ["mise", "x", "--", "npm-registry-mcp"],
			"enabled": false,
			"type": "local",
		},
	},
	"permission": {
		"bash": {
			"*": "allow",
			"bat *": "allow",
			"bat*": "allow",
			"cat *": "allow",
			"cat*": "allow",
			"cd *": "allow",
			"cd*": "allow",
			"date*": "allow",
			"delta *": "allow",
			"delta*": "allow",
			"diff *": "allow",
			"diff*": "allow",
			"du *": "allow",
			"du*": "allow",
			"dust *": "allow",
			"dust*": "allow",
			"echo*": "allow",
			"exa *": "allow",
			"exa*": "allow",
			"fd *": "allow",
			"fd*": "allow",
			"find *": "allow",
			"find*": "allow",
			"git diff*": "allow",
			"git log*": "allow",
			"git ls-files*": "allow",
			"git rev-parse*": "allow",
			"git show*": "allow",
			"git status *": "allow",
			"git status*": "allow",
			"grep *": "allow",
			"grep*": "allow",
			"head*": "allow",
			"ls *": "allow",
			"ls*": "allow",
			"lsd *": "allow",
			"lsd*": "allow",
			"mkdir*": "allow",
			"pwd*": "allow",
			"rg *": "allow",
			"rg*": "allow",
			"sd *": "allow",
			"sd*": "allow",
			"sed *": "allow",
			"sed*": "allow",
			"sort*": "allow",
			"tail*": "allow",
			"tree*": "allow",
			"wc*": "allow",
		},
		"codesearch": "allow",
		"doom_loop": "allow",
		"edit": {
			"*": "allow",
			"**/.oxfmtrc.json": "deny",
			"**/.oxlintrc.json": "deny",
			"**/biome.jsonc": "deny",
		},
		"external_directory": "allow",
		"glob": "allow",
		"grep": "allow",
		"list": "allow",
		"lsp": "allow",
		"question": "allow",
		"read": "allow",
		"skill": "allow",
		"task": "allow",
		"todoread": "allow",
		"todowrite": "allow",
		"webfetch": "allow",
		"websearch": "allow",
	},
	"plugin": [
		"opencode-wakatime",
		"@nick-vi/opencode-type-inject",
		"@mohak34/opencode-notifier@latest",
		"opencode-goal-plugin",
	],
	"provider": {
		"openai": {
			"models": {
				"gpt-5.4": {
					"limit": { "context": 200000, "output": 128000 },
				},
				"gpt-5.5": {
					"limit": { "context": 200000, "output": 128000 },
				},
			},
		},
	},
	"shell": "fish",
}
