{
	"auto-format": {
		"PostToolUse": [
			{
				"hooks": [
					{
						"command": "bash scripts/quiet-on-success.sh bash scripts/format-lint-relevant.sh",
						"timeout": 30,
						"type": "command"
					}
				],
				"matcher": "(write_to_file|replace_file_content|multi_replace_file_content)"
			}
		]
	},
	"run-tests": {
		"PostToolUse": [
			{
				"hooks": [
					{
						"command": "bash scripts/quiet-on-success.sh bash scripts/test-relevant.sh",
						"timeout": 45,
						"type": "command"
					}
				],
				"matcher": "(write_to_file|replace_file_content|multi_replace_file_content)"
			}
		]
	},
	"type-check": {
		"PostToolUse": [
			{
				"hooks": [
					{
						"command": "bash scripts/quiet-on-success.sh pnpm run type-check:agent",
						"timeout": 30,
						"type": "command"
					}
				],
				"matcher": "(write_to_file|replace_file_content|multi_replace_file_content)"
			}
		]
	}
}
