{
	"compilerOptions": {
		"noEmit": true,
		"paths": {
			"$script-types/*": ["./scripts/types/*"],
			"$script-utilities/*": ["./scripts/utilities/*"]
		},
		"rootDir": ".",
		"sourceMap": false,
		"tsBuildInfoFile": "./node_modules/.tsbuildinfo-scripts"
	},
	"extends": "./tsconfig.base.json",
	"include": ["scripts/**/*.ts"]
}
